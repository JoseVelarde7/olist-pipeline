# Copiar este archivo a .env y completar con las credenciales reales.
# El archivo .env nunca debe subirse al repositorio.

# Conexion a MariaDB (debe estar instalado en la maquina host, no en Docker)
OLIST_DB_HOST=host.docker.internal
OLIST_DB_PORT=3306
OLIST_DB_USER=user
OLIST_DB_PASSWORD=password
OLIST_DB_NAME=olist
